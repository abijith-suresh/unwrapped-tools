---
import MarketingLayout from "@/layouts/MarketingLayout.astro";

const features = [
  {
    category: "Comparison",
    items: [
      {
        title: "Live side-by-side diff",
        description:
          "The diff updates automatically as you type, paste, drop, or open files. Original stays on the left, modified stays on the right.",
      },
      {
        title: "Changes-only mode",
        description:
          "Focus on changed sections while still keeping nearby context. Jump through edits without manually scanning the whole table.",
      },
    ],
  },
  {
    category: "Config Workflows",
    items: [
      {
        title: "Structured config compare",
        description:
          "twish is especially useful for JSON, YAML, .env files, CI workflows, and other text-based config files.",
      },
      {
        title: "Syntax-aware editing surface",
        description:
          "CodeMirror 6 provides an editor surface that feels familiar for developer-oriented file formats.",
      },
      {
        title: "Per-panel language control",
        description:
          "Pick a language for each side independently when you want syntax highlighting to match the file you are comparing.",
      },
    ],
  },
  {
    category: "Input",
    items: [
      {
        title: "Paste text",
        description: "Type or paste any text directly into the editor panels. No file required.",
      },
      {
        title: "Drag & drop files",
        description:
          "Drag any text file from your filesystem and drop it onto a panel to load its contents.",
      },
      {
        title: "File open button",
        description:
          "Click Open file or press Ctrl+O to use the native file picker for the active panel.",
      },
    ],
  },
  {
    category: "PWA & Offline",
    items: [
      {
        title: "Installable",
        description: "Install twish as a desktop app from the browser's install prompt.",
      },
      {
        title: "Fully offline",
        description:
          "After the first visit, twish works with no internet connection. All assets are cached by the service worker.",
      },
      {
        title: "No data sent anywhere",
        description:
          "There is no server-side diffing. File contents stay on your device and the app remains usable offline after first load.",
      },
    ],
  },
  {
    category: "Navigation",
    items: [
      {
        title: "Live diff toolbar",
        description:
          "The toolbar keeps updating state visible and lets you swap panels, clear the workspace, and tune the diff view.",
      },
      {
        title: "Ctrl+O — Open file",
        description: "Open the file picker for the currently focused panel.",
      },
      {
        title: "Ctrl+Shift+C — Clear",
        description: "Clear both editor panels and reset the diff view.",
      },
    ],
  },
];
---

<MarketingLayout
  title="Features — twish"
  description="Everything twish can do — side-by-side diffing, structured JSON/YAML comparison, file drag-and-drop, and full offline support."
>
  <div class="max-w-3xl mx-auto px-6 py-16">
    <p class="font-mono text-xs text-cat-blue uppercase tracking-widest mb-4">Features</p>
    <h1 class="font-[Manrope,sans-serif] font-extrabold text-4xl text-cat-text mb-3">
      What twish can do
    </h1>
    <p class="font-[Manrope,sans-serif] text-cat-subtext0 mb-12">
      A local-first compare workflow for configs, code, and other text-based files.
    </p>

    <div class="flex flex-col gap-10">
      {
        features.map((section) => (
          <div>
            <span class="inline-block font-mono text-xs text-cat-blue uppercase tracking-widest border border-cat-blue px-2 py-0.5 mb-4">
              {section.category}
            </span>
            <div class="border border-cat-surface1 divide-y divide-cat-surface1">
              {section.items.map((item) => (
                <div class="px-5 py-4">
                  <h3 class="font-[Manrope,sans-serif] font-semibold text-sm text-cat-text tracking-wide mb-1">
                    {item.title}
                  </h3>
                  <p class="font-[Manrope,sans-serif] text-sm text-cat-subtext0 leading-relaxed">
                    {item.description}
                  </p>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <section class="border-t border-cat-surface1 py-20 text-center">
    <h2 class="font-[Manrope,sans-serif] text-2xl font-semibold text-cat-text mb-4">
      Ready to try it?
    </h2>
    <p class="text-cat-subtext0 mb-8 max-w-md mx-auto font-[Manrope,sans-serif]">
      Compare your configs locally — no uploads, no accounts, no tracking.
    </p>
    <a
      href="/app"
      class="inline-flex items-center gap-2 bg-cat-blue text-cat-bg font-semibold font-[Manrope,sans-serif] text-sm px-6 py-3 rounded-sm hover:opacity-90 transition-opacity no-underline"
    >
      Open twish →
    </a>
  </section>
</MarketingLayout>
