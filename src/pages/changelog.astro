---
import MarketingLayout from "@/layouts/MarketingLayout.astro";

function formatReleaseDate(date: string) {
  const [year, month, day] = date.split("-").map(Number);

  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(new Date(Date.UTC(year, month - 1, day)));
}

const releases = [
  {
    version: "1.0.0",
    date: "2026-03-28",
    tag: null,
    changes: [
      "Refined product positioning around local-first config comparison",
      "Live side-by-side diff for code, text, and structured config files",
      "Desktop-first PWA workflow with local file input and offline support",
      "Updated docs, marketing pages, and app copy to match the live diff interaction model",
    ],
  },
  {
    version: "0.9.0",
    date: "2026-02-14",
    tag: "pre-release",
    changes: [
      "Added per-panel language selector for independent syntax highlighting on each side",
      "Improved drag-and-drop reliability across Chrome, Firefox, and Edge",
      "Introduced Changes-only mode to filter the diff table to changed lines only",
      "Fixed service worker cache invalidation on deploy so stale assets no longer persist",
      "Minor performance improvements to the diff engine for large files",
    ],
  },
];
---

<MarketingLayout
  title="Changelog — twish"
  description="Release history for twish — see what's new, what's improved, and what's been fixed in each version."
>
  <div class="max-w-2xl mx-auto px-6 py-16">
    <p class="font-mono text-xs text-cat-blue uppercase tracking-widest mb-4">Changelog</p>
    <h1 class="font-[Manrope,sans-serif] font-extrabold text-4xl text-cat-text mb-12">
      What's new in twish
    </h1>

    <div class="flex flex-col gap-10">
      {
        releases.map((release) => (
          <div>
            <div class="flex flex-wrap items-baseline gap-3 mb-5">
              <h2 class="font-[Manrope,sans-serif] font-extrabold text-3xl text-cat-text">
                v{release.version}
              </h2>
              {release.tag && (
                <span class="font-mono text-xs text-cat-blue border border-cat-blue px-2 py-0.5 uppercase tracking-widest">
                  {release.tag}
                </span>
              )}
              {release.date && (
                <time class="font-mono text-xs text-cat-overlay0" datetime={release.date}>
                  {formatReleaseDate(release.date)}
                </time>
              )}
            </div>
            <ul class="flex flex-col gap-2 list-none p-0">
              {release.changes.map((change) => (
                <li class="flex gap-3 items-start font-[Manrope,sans-serif] text-sm text-cat-subtext0 leading-relaxed">
                  <span
                    class="inline-block w-1.5 h-1.5 rounded-full bg-cat-blue flex-shrink-0 mt-1.5"
                    aria-hidden="true"
                  />
                  {change}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</MarketingLayout>
