---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="About — twish"
  description="twish is a local-first, open-source PWA for comparing config files and code — no uploads, no accounts, no server-side processing."
>
  <div class="max-w-2xl mx-auto px-6 py-16">
    <p class="font-mono text-xs text-cat-blue uppercase tracking-widest mb-4">About</p>
    <h1 class="font-[Manrope,sans-serif] font-extrabold text-4xl text-cat-text mb-10">
      About twish
    </h1>

    <div
      class="flex flex-col gap-5 font-[Manrope,sans-serif] text-sm text-cat-subtext0 leading-relaxed"
    >
      <p>
        twish started as a solution to a problem I kept running into at work: I manage a lot of
        config files across multiple environments, and knowing exactly <strong class="text-cat-text"
          >what changed between versions</strong
        > was getting tedious.
      </p>

      <p>
        Tools like{" "}
        <a
          href="https://www.diffchecker.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-cat-text underline underline-offset-2 decoration-cat-surface1 hover:decoration-cat-blue transition-colors"
        >
          diffchecker.com
        </a>{" "}
        are useful, but they're <strong class="text-cat-text">online-only</strong> — which means pasting
        potentially sensitive config values into a third-party server. That felt wrong.
      </p>

      <blockquote class="border-l-4 border-cat-blue pl-4 text-cat-text italic">
        twish is fully client-side once it loads. There is no server-side diffing, no file uploads,
        and no accounts.
      </blockquote>

      <p>
        Everything runs in your browser and stays on your machine. It is designed first for{" "}
        <strong class="text-cat-text">structured config comparison</strong>, then for general text
        and code diffing.
      </p>

      <p>
        It's open source under the MIT license. If you find it useful, star the repo or open a PR —
        contributions are welcome.
      </p>
    </div>

    <!-- Why twish section -->
    <div class="mt-12 mb-10">
      <h2 class="font-[Manrope,sans-serif] font-bold text-xl text-cat-text mb-6">Why twish?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="bg-cat-surface0 border border-cat-surface1 rounded-sm p-5">
          <div class="text-cat-blue mb-2" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="18" height="18" x="3" y="3" rx="2"></rect>
              <path d="M7 7h10"></path>
              <path d="M7 12h10"></path>
              <path d="M7 17h10"></path>
            </svg>
          </div>
          <h3 class="font-[Manrope,sans-serif] font-semibold text-sm text-cat-text mb-1">
            Local-first
          </h3>
          <p class="font-[Manrope,sans-serif] text-xs text-cat-subtext0 leading-relaxed">
            Your files never leave your machine. Diff happens entirely in the browser.
          </p>
        </div>
        <div class="bg-cat-surface0 border border-cat-surface1 rounded-sm p-5">
          <div class="text-cat-blue mb-2" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
              ></path>
            </svg>
          </div>
          <h3 class="font-[Manrope,sans-serif] font-semibold text-sm text-cat-text mb-1">
            Private by design
          </h3>
          <p class="font-[Manrope,sans-serif] text-xs text-cat-subtext0 leading-relaxed">
            No analytics, no tracking, no third-party services watching your data.
          </p>
        </div>
        <div class="bg-cat-surface0 border border-cat-surface1 rounded-sm p-5">
          <div class="text-cat-blue mb-2" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 20h.01"></path>
              <path d="M8.5 16.429a5 5 0 0 1 7 0"></path>
              <path d="M5 12.859a10 10 0 0 1 5.17-2.69"></path>
              <path d="M19 12.859a10 10 0 0 0-2.007-1.523"></path>
              <path d="M2 8.82a15 15 0 0 1 4.177-2.643"></path>
              <path d="M22 8.82a15 15 0 0 0-11.288-3.764"></path>
              <line x1="2" x2="22" y1="2" y2="22"></line>
            </svg>
          </div>
          <h3 class="font-[Manrope,sans-serif] font-semibold text-sm text-cat-text mb-1">
            Works offline
          </h3>
          <p class="font-[Manrope,sans-serif] text-xs text-cat-subtext0 leading-relaxed">
            Install as a PWA and use it anywhere — no internet required after first load.
          </p>
        </div>
      </div>
    </div>

    <!-- Built with section -->
    <div class="mb-10">
      <h2 class="font-[Manrope,sans-serif] font-bold text-xl text-cat-text mb-4">Built with</h2>
      <div class="flex flex-wrap gap-2">
        {
          ["Astro 5", "SolidJS", "CodeMirror 6", "Tailwind CSS v4", "TypeScript", "Bun"].map(
            (tech) => (
              <span class="font-mono text-xs text-cat-blue border border-cat-blue/40 bg-cat-blue/5 px-3 py-1 rounded-sm">
                {tech}
              </span>
            )
          )
        }
      </div>
    </div>

    <div class="pt-4">
      <a
        href="https://github.com/abijith-suresh/twish"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-semibold text-sm text-cat-blue border border-cat-blue hover:bg-cat-blue hover:text-cat-bg transition-colors px-5 py-2.5 no-underline"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>
  </div>
</MarketingLayout>
