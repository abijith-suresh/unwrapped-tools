---
import Base from "@/layouts/Base.astro";
import ToolGrid from "@/components/ToolGrid.astro";
import CommandPalette from "@/components/CommandPalette";
import ThemePicker from "@/components/ThemePicker";
---

<Base title="unwrapped.tools">
  <div
    style="display: flex; flex-direction: column; min-height: 100dvh; background-color: var(--bg-primary);"
  >
    <!-- Header -->
    <header
      style="
        position: sticky;
        top: 0;
        z-index: 40;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        height: 3.5rem;
        background-color: var(--bg-primary);
        border-bottom: 1px solid var(--border);
      "
    >
      <a
        href="/"
        style="font-weight: 700; color: var(--text-primary); text-decoration: none; font-size: 1.05rem; letter-spacing: -0.01em;"
      >
        unwrapped.tools
      </a>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <ThemePicker client:load />
        <CommandPalette client:load />
      </div>
    </header>

    <!-- Main content -->
    <main style="flex: 1;">
      <!-- Hero -->
      <section
        style="
          text-align: center;
          padding: 4rem 1.5rem 3rem;
          max-width: 640px;
          margin: 0 auto;
        "
      >
        <h1
          style="
            font-size: clamp(1.75rem, 5vw, 2.75rem);
            font-weight: 800;
            color: var(--text-primary);
            margin: 0 0 1rem;
            letter-spacing: -0.03em;
            line-height: 1.15;
          "
        >
          Developer tools, unwrapped.
        </h1>
        <p
          style="
            font-size: 1.05rem;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.6;
          "
        >
          Fast, local-first tools for everyday dev work. No server, no uploads, no tracking.
        </p>
      </section>

      <!-- Tool grid -->
      <div
        style="
          max-width: 72rem;
          margin: 0 auto;
          padding: 0 1.5rem 4rem;
        "
      >
        <ToolGrid />
      </div>
    </main>

    <!-- Footer -->
    <footer
      style="
        border-top: 1px solid var(--border);
        padding: 1.25rem 1.5rem;
        text-align: center;
        font-size: 0.8rem;
        color: var(--text-muted);
      "
    >
      <p style="margin: 0;">
        MIT License &middot;
        <a
          href="https://github.com/abijith-suresh/unwrapped-tools"
          style="color: var(--accent-primary); text-decoration: none;"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      </p>
    </footer>
  </div>
</Base>
