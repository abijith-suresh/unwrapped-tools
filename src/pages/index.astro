---
import LandingShell from "@/layouts/LandingShell.astro";
import ToolSearch from "@/components/ToolSearch";
import { tools } from "@/tools/registry";

const toolCount = tools.length;
---

<LandingShell title="unwrapped.tools">
  <header class="lp-hero">
    <div class="lp-hero-left">
      <h1 class="lp-brand-name">
        unwrapped<span class="lp-brand-tld">.tools</span>
      </h1>
      <p class="lp-brand-tag">{toolCount} tools &middot; local-only &middot; no tracking</p>
    </div>
    <p class="lp-hero-pitch">
      Browser-native tools for developers. Everything runs locally &mdash; no accounts, no server,
      nothing leaves your machine.
    </p>
  </header>

  <ToolSearch client:load />
</LandingShell>

<!--
  Landing page styles — lp- prefix throughout.
  is:global required: ToolSearch is a SolidJS client:load island;
  Astro scoped styles cannot reach inside it at build time.
-->
<style is:global>
  /* ── Hero ───────────────────────────────────────────────────────────────── */

  .lp-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(2.5rem, 6vw, 5rem);
    align-items: end;
    padding-bottom: clamp(2rem, 4vh, 3.5rem);
    margin-bottom: clamp(1.5rem, 3vh, 2.5rem);
    border-bottom: 1px solid var(--border);
  }

  .lp-brand-name {
    font-family: var(--font-mono);
    font-size: clamp(2.5rem, 3vw + 1rem, 4rem);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0;
  }

  .lp-brand-tld {
    color: var(--accent-primary);
  }

  .lp-brand-tag {
    margin: 0.625rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    letter-spacing: 0.01em;
    line-height: 1.5;
  }

  .lp-hero-pitch {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1vw + 0.5rem, 1.25rem);
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
    align-self: center;
  }

  /* ── Search ─────────────────────────────────────────────────────────────── */

  .lp-search {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--border);
    padding: 0.875rem 1.25rem;
    transition: border-color 0.15s;
  }

  .lp-search--focused {
    border-color: var(--accent-primary);
  }

  .lp-search-icon {
    width: 16px;
    height: 16px;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .lp-search-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--text-primary);
  }

  .lp-search-input::placeholder {
    color: var(--text-muted);
  }

  .lp-search-clear {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0;
    font-size: 1.125rem;
    line-height: 1;
    flex-shrink: 0;
    transition: color 0.1s;
  }

  .lp-search-clear:hover {
    color: var(--text-primary);
  }

  .lp-search-hint {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    flex-shrink: 0;
  }

  .lp-search-hint kbd {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    padding: 1px 5px;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* ── Results table ───────────────────────────────────────────────────────── */

  .lp-results {
    margin-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  /* ── Tool row ────────────────────────────────────────────────────────────── */
  /*
   * Grid: icon (20px) | name + description stacked (1fr) | category (auto)
   * The right-anchored category column fills the horizontal edge —
   * no blank space on either side at any viewport width.
   */

  .lp-row {
    display: grid;
    grid-template-columns: 20px 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 0.875rem;
    row-gap: 0.25rem;
    align-items: start;
    padding: 0.875rem 0.5rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background-color 0.1s;
  }

  .lp-row:hover,
  .lp-row--active {
    background-color: color-mix(in srgb, var(--accent-primary) 7%, transparent);
  }

  /* Icon — spans both rows, vertically centered */
  .lp-row-icon {
    grid-column: 1;
    grid-row: 1 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    color: var(--text-muted);
    transition: color 0.1s;
  }

  .lp-row:hover .lp-row-icon,
  .lp-row--active .lp-row-icon {
    color: var(--accent-primary);
  }

  /* Name — row 1, col 2 */
  .lp-row-name {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.1s;
  }

  .lp-row:hover .lp-row-name,
  .lp-row--active .lp-row-name {
    color: var(--accent-primary);
  }

  /* Category — row 1, col 3 (right edge anchor) */
  .lp-row-cat {
    grid-column: 3;
    grid-row: 1;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
    letter-spacing: 0.03em;
    text-align: right;
    align-self: center;
  }

  /* Description — row 2, col 2 (wraps freely) */
  .lp-row-desc {
    grid-column: 2;
    grid-row: 2;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  /* ── New badge ───────────────────────────────────────────────────────────── */

  .lp-badge {
    font-family: var(--font-sans);
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-primary);
    border: 1px solid var(--accent-primary);
    border-radius: 3px;
    padding: 0 3px;
    line-height: 1.5;
  }

  /* ── Empty state ─────────────────────────────────────────────────────────── */

  .lp-empty {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--text-muted);
    padding: 3rem 0.5rem;
    margin: 0;
  }

  /* ── Mobile (≤ 640px) ────────────────────────────────────────────────────── */

  @media (max-width: 640px) {
    /* Hero stacks vertically */
    .lp-hero {
      grid-template-columns: 1fr;
      row-gap: 1.5rem;
      align-items: start;
    }

    /* Drop category column — icon + name + description only */
    .lp-row {
      grid-template-columns: 18px 1fr;
    }

    .lp-row-cat {
      display: none;
    }
  }

  /* ── Reduced motion ──────────────────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .lp-search,
    .lp-row,
    .lp-row-icon,
    .lp-row-name,
    .lp-search-clear {
      transition: none;
    }
  }
</style>
