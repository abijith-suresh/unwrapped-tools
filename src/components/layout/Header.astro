---
import GitHub from "@/components/icons/GitHub.astro";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/features", label: "Features" },
  { href: "/docs", label: "Docs" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<!-- Main content should have id="main-content" for skip-to-content link -->
<header class="sticky top-0 z-[100] bg-cat-bg border-b border-cat-surface1">
  <div class="max-w-7xl mx-auto px-6 py-2.5 flex items-center justify-between">
    <a
      href="/"
      class="font-[Manrope,sans-serif] font-bold text-xl text-cat-text tracking-tight no-underline"
      aria-label="twish home"
    >
      twish
    </a>

    <nav class="hidden sm:flex items-center gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "font-[Manrope,sans-serif] text-sm no-underline px-3 py-1.5 transition-colors border-b-2 pb-0.5",
              currentPath === link.href || currentPath === link.href + "/"
                ? "text-cat-text border-cat-blue"
                : "text-cat-subtext0 hover:text-cat-text border-transparent",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1">
      <div class="w-px h-4 bg-cat-surface1 mx-2 hidden sm:block" aria-hidden="true"></div>

      <a
        href="https://github.com/abijith-suresh/twish"
        target="_blank"
        rel="noopener noreferrer"
        class="text-cat-subtext0 hover:text-cat-text transition-colors p-1.5 flex items-center"
        aria-label="View on GitHub"
      >
        <GitHub size={18} />
      </a>

      <a
        href="/app"
        class="ml-2 font-[Manrope,sans-serif] text-sm font-semibold text-cat-blue border border-cat-blue hover:bg-cat-blue hover:text-cat-bg transition-colors px-3 py-1.5 no-underline focus-visible:ring-2 focus-visible:ring-cat-blue focus-visible:ring-offset-2 focus-visible:ring-offset-cat-bg focus-visible:outline-none"
      >
        Open App
      </a>
    </div>
  </div>
</header>
