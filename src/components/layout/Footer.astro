---
// Year computed at build time (Astro SSG) — rebuild annually or use a dynamic route
const year = new Date().getFullYear();
---

<footer class="border-t border-cat-surface1 bg-cat-bg">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between flex-wrap gap-4">
    <span class="font-mono text-xs text-cat-overlay0 uppercase tracking-widest">
      &copy; {year} twish &middot; MIT License
    </span>
    <div class="flex items-center gap-6 flex-wrap">
      <a
        href="/features"
        class="font-mono text-xs text-cat-overlay0 hover:text-cat-subtext0 no-underline transition-colors"
      >
        Features
      </a>
      <a
        href="/docs"
        class="font-mono text-xs text-cat-overlay0 hover:text-cat-subtext0 no-underline transition-colors"
      >
        Docs
      </a>
      <a
        href="/changelog"
        class="font-mono text-xs text-cat-overlay0 hover:text-cat-subtext0 no-underline transition-colors"
      >
        Changelog
      </a>
      <a
        href="/about"
        class="font-mono text-xs text-cat-overlay0 hover:text-cat-subtext0 no-underline transition-colors"
      >
        About
      </a>
      <a
        href="https://github.com/abijith-suresh/twish"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs text-cat-overlay0 hover:text-cat-subtext0 no-underline transition-colors"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
