---
interface Props {
  title: string;
  description: string;
  icon: string;
  num?: string;
}

const { title, description, icon, num } = Astro.props;
---

<div
  class="group relative bg-cat-surface0 border border-cat-surface1 hover:border-cat-blue hover:bg-cat-surface0/50 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 p-6 overflow-hidden"
>
  {
    num && (
      <span
        class="absolute top-0 right-3 font-mono text-[5rem] text-cat-text/5 leading-none pointer-events-none select-none"
        aria-hidden="true"
      >
        {num}
      </span>
    )
  }
  <div
    class="text-cat-blue mb-3 group-hover:scale-110 transition-transform duration-200 inline-block"
    aria-hidden="true"
    set:html={icon}
  />
  <h3 class="font-[Manrope,sans-serif] font-bold text-sm text-cat-text tracking-wide mb-2">
    {title}
  </h3>
  <p class="font-[Manrope,sans-serif] text-sm text-cat-subtext0 leading-relaxed">
    {description}
  </p>
</div>
