---

---

<section class="px-6 py-24">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left column: text + CTAs -->
      <div>
        <p class="font-mono text-xs text-cat-blue uppercase tracking-widest mb-6">
          desktop-first &middot; offline &middot; open source
        </p>

        <h1
          class="font-[Manrope,sans-serif] font-extrabold text-[clamp(3rem,7vw,5.5rem)] leading-[1.05] mb-6"
        >
          Compare configs.<br />
          <span class="text-cat-subtext0">Stay local.</span>
        </h1>

        <p
          class="font-[Manrope,sans-serif] text-base text-cat-subtext0 leading-relaxed max-w-lg mb-10"
        >
          twish is a developer-first PWA for comparing JSON, YAML, env files, code, and plain text
          with live diffing and zero uploads.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="/app"
            class="inline-flex items-center gap-2 bg-cat-blue text-cat-bg font-semibold font-[Manrope,sans-serif] text-sm px-6 py-3 rounded-sm hover:opacity-90 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cat-blue focus-visible:ring-offset-2 focus-visible:ring-offset-cat-bg no-underline"
          >
            Open the diff tool →
          </a>
          <a
            href="https://github.com/abijith-suresh/twish"
            target="_blank"
            rel="noopener noreferrer"
            class="font-[Manrope,sans-serif] text-sm font-medium text-cat-subtext0 hover:text-cat-text transition-colors px-6 py-3 no-underline"
          >
            GitHub ↗
          </a>
        </div>
      </div>

      <!-- Right column: animated diff preview -->
      <div aria-hidden="true" class="hero-preview-wrapper">
        <div class="hero-preview">
          <!-- Left panel: "before" -->
          <div class="preview-panel">
            <div class="panel-header">
              <span class="panel-dot panel-dot--red"></span>
              <span class="panel-dot panel-dot--yellow"></span>
              <span class="panel-dot panel-dot--green"></span>
              <span class="panel-filename">config.yaml</span>
            </div>
            <pre
              class="panel-content"><span class="diff-line line-removed anim-line-1">- version: "1.0"</span>
<span class="diff-line line-unchanged anim-line-2">  name: twish</span>
<span class="diff-line line-removed anim-line-3">- port: 3000</span>
<span class="diff-line line-unchanged anim-line-4">  debug: false</span>
<span class="diff-line line-unchanged anim-line-5">  region: us-east</span></pre>
          </div>
          <!-- Right panel: "after" -->
          <div class="preview-panel">
            <div class="panel-header">
              <span class="panel-dot panel-dot--red"></span>
              <span class="panel-dot panel-dot--yellow"></span>
              <span class="panel-dot panel-dot--green"></span>
              <span class="panel-filename">config.prod.yaml</span>
            </div>
            <pre
              class="panel-content"><span class="diff-line line-added anim-line-1">+ version: "2.0"</span>
<span class="diff-line line-unchanged anim-line-2">  name: twish</span>
<span class="diff-line line-added anim-line-3">+ port: 8080</span>
<span class="diff-line line-unchanged anim-line-4">  debug: false</span>
<span class="diff-line line-unchanged anim-line-5">  region: us-east</span></pre>
          </div>
        </div>
        <!-- diff stats bar -->
        <div class="preview-stats">
          <span class="stats-added">+2 added</span>
          <span class="stats-divider">&middot;</span>
          <span class="stats-removed">-2 removed</span>
          <span class="stats-divider">&middot;</span>
          <span class="stats-label">3 unchanged</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-preview-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid #45475a;
    background: #1e1e2e;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.4),
      0 20px 60px -10px rgba(137, 180, 250, 0.08);
  }

  .hero-preview {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid #45475a;
  }

  .preview-panel {
    background: #313244;
    overflow: hidden;
  }

  .preview-panel:first-child {
    border-right: 1px solid #45475a;
  }

  .panel-header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    background: #1e1e2e;
    border-bottom: 1px solid #45475a;
  }

  .panel-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
  }

  .panel-dot--red {
    background: #f38ba8;
  }

  .panel-dot--yellow {
    background: #f9e2af;
  }

  .panel-dot--green {
    background: #a6e3a1;
  }

  .panel-filename {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    color: #a6adc8;
    margin-left: 0.25rem;
    letter-spacing: 0.02em;
  }

  .panel-content {
    margin: 0;
    padding: 0.75rem 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    line-height: 1.7;
    background: transparent;
    overflow: hidden;
  }

  .diff-line {
    display: block;
    padding: 0 0.75rem;
    opacity: 0;
    animation: fadeSlideIn 0.3s ease forwards;
  }

  .line-removed {
    background-color: rgba(60, 18, 48, 0.6);
    color: #f38ba8;
  }

  .line-added {
    background-color: rgba(26, 48, 34, 0.6);
    color: #a6e3a1;
  }

  .line-unchanged {
    color: #cdd6f4;
  }

  /* Staggered animation delays for each line */
  .anim-line-1 {
    animation-delay: 0.1s;
  }
  .anim-line-2 {
    animation-delay: 0.25s;
  }
  .anim-line-3 {
    animation-delay: 0.4s;
  }
  .anim-line-4 {
    animation-delay: 0.55s;
  }
  .anim-line-5 {
    animation-delay: 0.7s;
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .preview-stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: #1e1e2e;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    opacity: 0;
    animation: fadeSlideIn 0.3s ease 0.9s forwards;
  }

  .stats-added {
    color: #a6e3a1;
    font-weight: 700;
  }

  .stats-removed {
    color: #f38ba8;
    font-weight: 700;
  }

  .stats-divider {
    color: #585b70;
  }

  .stats-label {
    color: #6c7086;
  }
</style>
