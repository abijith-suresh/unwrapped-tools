<section class="px-6 py-24">
  <div class="max-w-2xl mx-auto">
    <p class="font-mono text-xs text-cat-blue uppercase tracking-widest mb-6">
      desktop-first &middot; offline &middot; open source
    </p>

    <h1
      class="font-[Manrope,sans-serif] font-extrabold text-[clamp(3rem,7vw,5.5rem)] leading-[0.95] mb-6"
    >
      Compare configs.<br />
      <span class="text-cat-subtext0">Stay local.</span>
    </h1>

    <p class="font-[Manrope,sans-serif] text-base text-cat-subtext0 leading-relaxed max-w-lg mb-10">
      twish is a developer-first PWA for comparing JSON, YAML, env files, code, and plain text with
      live diffing and zero uploads.
    </p>

    <div class="flex flex-wrap gap-4">
      <a
        href="/app"
        class="font-[Manrope,sans-serif] text-sm font-semibold text-cat-blue border border-cat-blue hover:bg-cat-blue hover:text-cat-bg transition-colors px-6 py-3 no-underline"
      >
        Open the diff tool
      </a>
      <a
        href="https://github.com/abijith-suresh/twish"
        target="_blank"
        rel="noopener noreferrer"
        class="font-[Manrope,sans-serif] text-sm font-medium text-cat-subtext0 hover:text-cat-text transition-colors px-6 py-3 no-underline"
      >
        GitHub ↗
      </a>
    </div>
  </div>
</section>
