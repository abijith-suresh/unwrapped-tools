---
import BaseLayout from "@/layouts/Base.astro";
import type { Tool } from "@/tools/registry";

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<BaseLayout title={tool.name} description={tool.description}>
  <div class="flex min-h-[calc(100vh-4rem)] flex-col">
    <!-- Header / breadcrumb -->
    <header class="border-b border-[var(--border)] bg-[var(--bg-primary)]">
      <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="mb-3 flex items-center gap-1.5 text-xs text-[var(--text-muted)]">
          <a href="/" class="transition-colors duration-100 hover:text-[var(--text-primary)]">
            Home
          </a>
          <span>/</span>
          <a href="/" class="transition-colors duration-100 hover:text-[var(--text-primary)]">
            Tools
          </a>
          <span>/</span>
          <span class="text-[var(--text-secondary)]">{tool.name}</span>
        </nav>

        <!-- Tool heading -->
        <div class="flex flex-wrap items-baseline gap-3">
          <h1 class="text-xl font-bold text-[var(--text-primary)] sm:text-2xl">
            {tool.name}
          </h1>
          <span
            class="rounded-md border border-[var(--border)] bg-[var(--bg-secondary)] px-2 py-0.5 text-xs text-[var(--text-muted)]"
          >
            {tool.category}
          </span>
          {
            tool.isNew && (
              <span class="rounded-md bg-[var(--accent-success)] px-2 py-0.5 text-xs font-semibold text-[var(--text-primary)] opacity-90">
                New
              </span>
            )
          }
        </div>

        <p class="mt-1 text-sm text-[var(--text-muted)]">
          {tool.description}
        </p>
      </div>
    </header>

    <!-- Tool content -->
    <main class="flex flex-1 flex-col">
      <div class="mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 lg:px-8">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>
