---
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Fast, local-first developer tools. No server, no uploads, no tracking.",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? "https://unwrapped-tools.vercel.app"
);
const fullTitle = title === "unwrapped.tools" ? title : `${title} — unwrapped.tools`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL(ogImage, Astro.site ?? "https://unwrapped-tools.vercel.app")}
    />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={new URL(ogImage, Astro.site ?? "https://unwrapped-tools.vercel.app")}
    />
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <slot name="head" />
    <!-- Theme init: runs before paint to prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("unwrapped-theme");
        const theme = ["dracula", "catppuccin", "nord", "gruvbox"].includes(stored)
          ? stored
          : "dracula";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
