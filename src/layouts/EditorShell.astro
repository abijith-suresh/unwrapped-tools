---
import { ViewTransitions } from "astro:transitions";

import CommandPalette from "@/components/CommandPalette";
import SettingsModal from "@/components/SettingsModal";
import "@/styles/global.css";
import { tools } from "@/tools/registry";
import type { ToolCategory } from "@/tools/registry";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** If set, the matching sidebar item will be highlighted. */
  activeSlug?: string;
}

const {
  title,
  description = "Fast, local-first developer tools. No server, no uploads, no tracking.",
  ogImage = "/og-image.png",
  activeSlug,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? "https://unwrapped-tools.vercel.app"
);
const fullTitle = title === "unwrapped.tools" ? title : `${title} — unwrapped.tools`;

// Group tools by category, preserving registry order
const categoryOrder: ToolCategory[] = [
  "security",
  "text",
  "encoding",
  "data",
  "generators",
  "time",
  "network",
];

interface GroupedTool {
  category: ToolCategory;
  items: typeof tools;
}

const grouped: GroupedTool[] = categoryOrder
  .map((cat) => ({
    category: cat,
    items: tools.filter((t) => t.category === cat),
  }))
  .filter((g) => g.items.length > 0);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL(ogImage, Astro.site ?? "https://unwrapped-tools.vercel.app")}
    />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={new URL(ogImage, Astro.site ?? "https://unwrapped-tools.vercel.app")}
    />
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <!-- Theme init: runs before paint to prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("unwrapped-theme");
        const theme = ["dracula", "catppuccin", "nord", "gruvbox"].includes(stored)
          ? stored
          : "catppuccin";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <ViewTransitions />
  </head>
  <body>
    <!-- ═══════════════════════════════════════════════════
         EDITOR CHROME — persistent shell, never swapped
         ═══════════════════════════════════════════════════ -->
    <div class="editor-root" transition:name="editor-root" transition:animate="none">
      <!-- ── TAB BAR ── -->
      <header class="tab-bar" transition:name="tab-bar" transition:animate="none">
        <!-- Hamburger (mobile only) -->
        <button
          id="sidebar-toggle"
          class="sidebar-toggle"
          aria-label="Toggle file explorer"
          aria-expanded="false"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <rect x="2" y="4" width="12" height="1.5" rx="0.75" fill="currentColor"></rect>
            <rect x="2" y="7.25" width="12" height="1.5" rx="0.75" fill="currentColor"></rect>
            <rect x="2" y="10.5" width="12" height="1.5" rx="0.75" fill="currentColor"></rect>
          </svg>
        </button>

        <!-- Active file tab -->
        <div class="tab-filename">
          <span class="tab-dot"></span>
          <span class="tab-name">
            {activeSlug ? `${activeSlug}.ts` : "readme.ts"}
          </span>
        </div>

        <!-- Right side controls -->
        <div class="tab-controls">
          <CommandPalette client:load />
          <a href="/" class="tab-brand" aria-label="Go to homepage"> unwrapped </a>
        </div>
      </header>

      <!-- ── BODY: SIDEBAR + MAIN PANE ── -->
      <div class="editor-body">
        <!-- ── SIDEBAR ── -->
        <nav
          id="sidebar"
          class:list={["sidebar", { "sidebar--open": false }]}
          aria-label="File explorer"
          transition:name="sidebar"
          transition:animate="none"
        >
          <div class="sidebar-section-label">EXPLORER</div>

          {
            grouped.map((group) => (
              <div class="sidebar-group">
                <div class="sidebar-category">{group.category}</div>
                <ul class="sidebar-list">
                  {group.items.map((tool) => (
                    <li>
                      <a
                        href={`/tools/${tool.slug}`}
                        class:list={[
                          "sidebar-item",
                          { "sidebar-item--active": tool.slug === activeSlug },
                        ]}
                        aria-current={tool.slug === activeSlug ? "page" : undefined}
                      >
                        <span class="sidebar-item-icon" aria-hidden="true">
                          {tool.slug === activeSlug ? "▸" : " "}
                        </span>
                        <span class="sidebar-item-name">{tool.slug}.ts</span>
                        {tool.isNew && <span class="sidebar-item-badge">new</span>}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>

        <!-- Sidebar backdrop (mobile) -->
        <div
          id="sidebar-backdrop"
          class:list={["sidebar-backdrop", { "sidebar-backdrop--visible": false }]}
          aria-hidden="true"
        >
        </div>

        <!-- ── MAIN PANE ── -->
        <main class="main-pane" id="main-pane">
          <div transition:name="main-pane" transition:animate="fade">
            <slot />
          </div>
        </main>
      </div>

      <!-- ── STATUS BAR ── -->
      <footer class="status-bar" transition:name="status-bar" transition:animate="none">
        <div class="status-left">
          <span class="status-item status-branch">
            <svg
              width="12"
              height="12"
              viewBox="0 0 16 16"
              fill="currentColor"
              aria-hidden="true"
              style="display:inline;vertical-align:middle;margin-right:3px;"
            >
              <path
                d="M5 3.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm0 2.122a2.25 2.25 0 1 0-1.5 0v.878A2.25 2.25 0 0 0 5.75 8.5h1.5v2.128a2.251 2.251 0 1 0 1.5 0V8.5h1.5a2.25 2.25 0 0 0 2.25-2.25v-.878a2.25 2.25 0 1 0-1.5 0v.878a.75.75 0 0 1-.75.75h-4.5A.75.75 0 0 1 5 6.25v-.878zm3.75 7.378a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm3-8.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0z"
              ></path>
            </svg>
            main
          </span>
          <span class="status-sep status-ts-sep" aria-hidden="true">|</span>
          <span class="status-item status-ts">&#10003; TypeScript</span>
        </div>

        <div class="status-right">
          <SettingsModal client:load />
          <span class="status-sep" aria-hidden="true">|</span>
          <span class="status-item status-gh">
            <a
              href="https://github.com/abijith-suresh/unwrapped-tools"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub repository"
              class="status-gh-link"
            >
              ~/gh
            </a>
          </span>
        </div>
      </footer>
    </div>

    <!-- Mobile sidebar toggle script -->
    <script>
      function initSidebarToggle() {
        const toggle = document.getElementById("sidebar-toggle");
        const sidebar = document.getElementById("sidebar");
        const backdrop = document.getElementById("sidebar-backdrop");

        if (!toggle || !sidebar || !backdrop) return;

        toggle.onclick = function () {
          const isOpen = sidebar.classList.contains("sidebar--open");
          if (isOpen) {
            sidebar.classList.remove("sidebar--open");
            backdrop.classList.remove("sidebar-backdrop--visible");
            toggle.setAttribute("aria-expanded", "false");
          } else {
            sidebar.classList.add("sidebar--open");
            backdrop.classList.add("sidebar-backdrop--visible");
            toggle.setAttribute("aria-expanded", "true");
          }
        };

        backdrop.onclick = function () {
          sidebar.classList.remove("sidebar--open");
          backdrop.classList.remove("sidebar-backdrop--visible");
          toggle.setAttribute("aria-expanded", "false");
        };
      }

      document.addEventListener("astro:page-load", initSidebarToggle);

      // Persist data-theme across View Transitions navigations.
      // astro:before-swap fires before the incoming DOM replaces the current DOM,
      // giving us a chance to copy the runtime attribute to the new document so
      // the CSS theme vars are never absent after a page swap.
      document.addEventListener("astro:before-swap", (ev) => {
        const e = ev as Event & { newDocument: Document };
        const theme = document.documentElement.getAttribute("data-theme");
        if (theme) e.newDocument.documentElement.setAttribute("data-theme", theme);
      });
    </script>

    <style>
      /* ── LAYOUT ── */
      .editor-root {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        overflow: hidden;
        background-color: var(--bg-primary);
        color: var(--text-primary);
        font-family: var(--font-mono);
      }

      /* ── TAB BAR ── */
      .tab-bar {
        display: flex;
        align-items: center;
        height: 2.5rem;
        min-height: 2.5rem;
        background-color: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
        padding: 0 0.75rem;
        gap: 0.5rem;
        flex-shrink: 0;
        z-index: 20;
      }

      .sidebar-toggle {
        display: none;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
        padding: 0.25rem;
        border-radius: 4px;
        flex-shrink: 0;
      }
      .sidebar-toggle:hover {
        color: var(--text-primary);
        background-color: var(--bg-tertiary);
      }

      .tab-filename {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        background-color: var(--bg-primary);
        border-left: 1px solid var(--border);
        border-right: 1px solid var(--border);
        padding: 0 0.875rem;
        height: 100%;
        font-size: 0.8rem;
        color: var(--text-secondary);
        flex-shrink: 0;
      }

      .tab-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background-color: var(--accent-primary);
        opacity: 0.7;
        flex-shrink: 0;
      }

      .tab-name {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-primary);
        white-space: nowrap;
      }

      .tab-controls {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-left: auto;
      }

      .tab-brand {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text-secondary);
        text-decoration: none;
        letter-spacing: -0.01em;
        white-space: nowrap;
      }
      .tab-brand:hover {
        color: var(--text-primary);
      }

      /* ── EDITOR BODY ── */
      .editor-body {
        display: flex;
        flex: 1;
        min-height: 0;
        overflow: hidden;
        position: relative;
      }

      /* ── SIDEBAR ── */
      .sidebar {
        width: 13rem;
        min-width: 13rem;
        background-color: var(--bg-secondary);
        border-right: 1px solid var(--border);
        overflow-y: auto;
        flex-shrink: 0;
        padding: 0.5rem 0;
        font-family: var(--font-mono);
        font-size: 0.75rem;
      }

      .sidebar-section-label {
        padding: 0.375rem 0.75rem 0.25rem;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--text-secondary);
        text-transform: uppercase;
      }

      .sidebar-group {
        margin-bottom: 0.125rem;
      }

      .sidebar-category {
        padding: 0.25rem 0.75rem 0.125rem;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--text-secondary);
        letter-spacing: 0.04em;
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .sidebar-category::before {
        content: "▾";
        font-size: 0.65rem;
        color: var(--text-secondary);
      }

      .sidebar-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .sidebar-item {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.2rem 0.75rem 0.2rem 1.25rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.75rem;
        line-height: 1.4;
        transition: background-color 0.1s;
        white-space: nowrap;
      }
      .sidebar-item:hover {
        background-color: var(--bg-tertiary);
        color: var(--text-primary);
      }
      .sidebar-item--active {
        background-color: color-mix(in srgb, var(--accent-primary) 15%, transparent);
        color: var(--text-primary);
      }

      .sidebar-item-icon {
        width: 0.75rem;
        flex-shrink: 0;
        color: var(--accent-primary);
        font-size: 0.65rem;
      }

      .sidebar-item-name {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .sidebar-item-badge {
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--accent-primary);
        border: 1px solid var(--accent-primary);
        border-radius: 3px;
        padding: 0 3px;
        line-height: 1.4;
        opacity: 0.8;
        flex-shrink: 0;
      }

      /* ── SIDEBAR BACKDROP (mobile) ── */
      .sidebar-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 29;
      }

      /* ── MAIN PANE ── */
      .main-pane {
        flex: 1;
        min-width: 0;
        overflow-y: auto;
        background-color: var(--bg-primary);
      }

      /* ── STATUS BAR ── */
      .status-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 1.625rem;
        min-height: 1.625rem;
        background-color: var(--accent-primary);
        padding: 0 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--bg-primary);
        flex-shrink: 0;
        z-index: 10;
      }

      .status-left,
      .status-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .status-item {
        white-space: nowrap;
      }

      .status-sep {
        opacity: 0.4;
      }

      .status-gh-link {
        color: inherit;
        text-decoration: none;
      }
      .status-gh-link:hover {
        text-decoration: underline;
      }

      /* ── MOBILE ── */
      @media (max-width: 767px) {
        .sidebar-toggle {
          display: flex;
        }

        .sidebar {
          position: fixed;
          top: 2.5rem;
          left: 0;
          bottom: 1.625rem;
          z-index: 30;
          transform: translateX(-100%);
          transition: transform 0.2s ease;
          width: 14rem;
          min-width: 14rem;
          border-right: 1px solid var(--border);
        }

        .sidebar--open {
          transform: translateX(0);
        }

        .sidebar-backdrop--visible {
          display: block;
        }

        .tab-brand {
          display: none;
        }

        .status-ts-sep,
        .status-ts {
          display: none;
        }
      }

      @media (min-width: 768px) {
        .sidebar-backdrop {
          display: none !important;
        }
      }
    </style>
  </body>
</html>
