---
import BaseLayout from "./BaseLayout.astro";
import Header from "@/components/layout/Header.astro";

interface Props {
  title?: string;
}

const { title = "twish — local config compare" } = Astro.props;
---

<BaseLayout
  title={title}
  description="Compare config files, code, and text locally with a desktop-first live diff."
  bodyClass="bg-cat-bg text-cat-text antialiased"
>
  <div class="flex flex-col h-screen overflow-hidden font-[Manrope,sans-serif]">
    <Header />

    <!-- App content fills the rest of the screen -->
    <main id="main-content" class="flex-1 min-h-0 overflow-hidden">
      <slot />
    </main>
  </div>
</BaseLayout>
